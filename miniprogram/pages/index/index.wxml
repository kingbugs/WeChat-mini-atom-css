<view class="w-full pb-15 {{theme === 'dark' ? 'page-dark' : ''}} {{holidayTheme ? 'page-holiday-' + holidayTheme : ''}}" style="background-color: {{theme === 'dark' ? '#0f172a' : (holidayTheme ? themeColors.bg : '#ffffff')}};">
  <view class="container mx-auto px-4">
    <!-- 顶部区域 -->
    <view class="pt-8 pb-6">
      <view class="flex items-center justify-between mb-4 flex-wrap" style="row-gap: 16rpx;">
        <view class="flex-1" style="min-width: 280rpx;">
          <text class="text-2xl font-bold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">原子化样式系统</text>
          <text class="text-sm block mt-1" style="color: {{theme === 'dark' ? '#94a3b8' : '#9ca3af'}};">基于 SCSS 的小程序样式方案</text>
        </view>
        <view class="flex gap-2">
          <button
            class="px-5 py-25 rounded-full text-sm font-medium transition-all shadow-md"
            style="background-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}}; color: #ffffff;"
            bindtap="toggleDarkMode"
          >
            {{theme === 'dark' ? '浅色' : '深色'}}
          </button>
          <button
            class="px-5 py-25 rounded-full text-sm font-medium transition-all"
            style="background-color: {{theme === 'dark' ? '#334155' : '#f3f4f6'}}; color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};"
            bindtap="resetHolidayTheme"
          >
            重置
          </button>
        </view>
      </view>

      <view class="rounded-2xl p-5" style="background-color: {{theme === 'dark' ? '#1e293b' : '#f3f4f6'}};">
        <view class="flex items-center justify-between flex-wrap" style="row-gap: 16rpx;">
          <view class="flex items-center gap-3 flex-1" style="min-width: 280rpx;">
            <view class="w-10 h-10 rounded-xl flex items-center justify-center flex-none" style="background-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}};">
              <text class="text-white text-lg">🎨</text>
            </view>
            <view class="flex-1">
              <text class="text-base font-semibold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">当前主题：{{holidayName || '默认主题'}}</text>
              <text class="text-xs mt-05 block" style="color: {{theme === 'dark' ? '#94a3b8' : '#9ca3af'}};">点击下方卡片切换节日主题</text>
            </view>
          </view>
          <view class="flex gap-1">
            <view class="w-3 h-3 rounded-full" style="background-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}};"></view>
            <view class="w-3 h-3 rounded-full" style="background-color: {{theme === 'dark' ? '#34d399' : (themeColors.success || '#10b981')}};"></view>
            <view class="w-3 h-3 rounded-full" style="background-color: {{theme === 'dark' ? '#fb923c' : (themeColors.warning || '#f59e0b')}};"></view>
            <view class="w-3 h-3 rounded-full" style="background-color: {{theme === 'dark' ? '#f87171' : (themeColors.danger || '#ef4444')}};"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 主题色彩体系 -->
    <view class="mb-8">
      <view class="flex items-center justify-between mb-4 flex-wrap" style="row-gap: 8rpx;">
        <text class="text-lg font-semibold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">主题色彩体系</text>
        <text class="text-xs" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">Primary / Success / Warning / Danger / Purple</text>
      </view>
      <view class="flex flex-wrap" style="margin-left: -12rpx; margin-right: -12rpx;">
        <view style="width: 20%; padding-left: 12rpx; padding-right: 12rpx; box-sizing: border-box; margin-bottom: 16rpx;">
          <view class="flex flex-col items-center">
            <view style="width: 112rpx; height: 112rpx; border-radius: 24rpx; background-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}}; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);"></view>
            <text class="text-xs mt-2 font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">Primary</text>
            <text class="text-[10px] mt-05 text-center" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">主色</text>
          </view>
        </view>
        <view style="width: 20%; padding-left: 12rpx; padding-right: 12rpx; box-sizing: border-box; margin-bottom: 16rpx;">
          <view class="flex flex-col items-center">
            <view style="width: 112rpx; height: 112rpx; border-radius: 24rpx; background-color: {{theme === 'dark' ? '#34d399' : (themeColors.success || '#10b981')}}; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);"></view>
            <text class="text-xs mt-2 font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">Success</text>
            <text class="text-[10px] mt-05 text-center" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">成功</text>
          </view>
        </view>
        <view style="width: 20%; padding-left: 12rpx; padding-right: 12rpx; box-sizing: border-box; margin-bottom: 16rpx;">
          <view class="flex flex-col items-center">
            <view style="width: 112rpx; height: 112rpx; border-radius: 24rpx; background-color: {{theme === 'dark' ? '#fb923c' : (themeColors.warning || '#f59e0b')}}; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);"></view>
            <text class="text-xs mt-2 font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">Warning</text>
            <text class="text-[10px] mt-05 text-center" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">警告</text>
          </view>
        </view>
        <view style="width: 20%; padding-left: 12rpx; padding-right: 12rpx; box-sizing: border-box; margin-bottom: 16rpx;">
          <view class="flex flex-col items-center">
            <view style="width: 112rpx; height: 112rpx; border-radius: 24rpx; background-color: {{theme === 'dark' ? '#f87171' : (themeColors.danger || '#ef4444')}}; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);"></view>
            <text class="text-xs mt-2 font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">Danger</text>
            <text class="text-[10px] mt-05 text-center" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">危险</text>
          </view>
        </view>
        <view style="width: 20%; padding-left: 12rpx; padding-right: 12rpx; box-sizing: border-box; margin-bottom: 16rpx;">
          <view class="flex flex-col items-center">
            <view style="width: 112rpx; height: 112rpx; border-radius: 24rpx; background-color: {{theme === 'dark' ? '#a78bfa' : (themeColors.purple || '#8b5cf6')}}; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);"></view>
            <text class="text-xs mt-2 font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">Purple</text>
            <text class="text-[10px] mt-05 text-center" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">紫色</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 按钮样式 -->
    <view class="mb-8">
      <text class="text-lg font-semibold mb-4 block" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">按钮样式</text>
      <view class="card">
        <text class="text-xs mb-3 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">主要按钮</text>
        <view class="flex" style="gap: 16rpx;">
          <button class="btn btn-primary flex-1">Primary</button>
          <button class="btn btn-success flex-1">Success</button>
        </view>
        <view class="flex" style="gap: 16rpx; margin-top: 16rpx;">
          <button class="btn btn-warning flex-1">Warning</button>
          <button class="btn btn-danger flex-1">Danger</button>
          <button class="btn btn-purple flex-1">Purple</button>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">空心按钮</text>
        <view class="flex" style="gap: 16rpx;">
          <button class="btn btn-outline btn-outline-primary flex-1">Primary</button>
          <button class="btn btn-outline btn-outline-success flex-1">Success</button>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">按钮尺寸</text>
        <view class="flex items-center" style="gap: 16rpx;">
          <button class="btn btn-primary btn-xs">XS</button>
          <button class="btn btn-primary btn-sm">SM</button>
          <button class="btn btn-primary btn-md">MD</button>
          <button class="btn btn-primary btn-lg">LG</button>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">特殊状态</text>
        <view class="flex" style="gap: 16rpx;">
          <button class="btn btn-primary btn-disabled flex-1">禁用状态</button>
          <button class="btn btn-block btn-primary">块级按钮</button>
        </view>
      </view>
    </view>

    <!-- 卡片组件 -->
    <view class="mb-8">
      <text class="text-lg font-semibold mb-4 block" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">卡片组件</text>
      <view class="flex flex-wrap" style="gap: 16rpx;">
        <view class="card card-sm card-hover" style="width: calc(50% - 8rpx);">
          <text class="text-sm font-semibold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">基础卡片</text>
          <text class="text-xs mt-1 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">支持 hover 效果</text>
        </view>
        <view class="card card-sm card-bordered" style="width: calc(50% - 8rpx);">
          <text class="text-sm font-semibold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">带边框卡片</text>
          <text class="text-xs mt-1 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">适合列表展示</text>
        </view>
        <view class="card card-md" style="width: 100%;">
          <view class="card-header">
            <text class="text-sm font-semibold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">卡片标题</text>
            <text class="text-xs" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">查看更多</text>
          </view>
          <view class="card-body">
            <text class="text-xs" style="color: {{theme === 'dark' ? '#94a3b8' : '#6b7280'}};">这是卡片内容区域，可以放置图片、文字等多种内容。支持主题色彩切换，在不同主题下显示不同的视觉效果。</text>
          </view>
          <view class="card-footer">
            <button class="btn btn-sm btn-primary">操作按钮</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 徽章与标签 -->
    <view class="mb-8">
      <text class="text-lg font-semibold mb-4 block" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">徽章与标签</text>
      <view class="card">
        <text class="text-xs mb-3 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">徽章 (Badge)</text>
        <view class="flex flex-wrap items-center" style="gap: 16rpx;">
          <view class="badge badge-primary">Primary</view>
          <view class="badge badge-success">Success</view>
          <view class="badge badge-warning">Warning</view>
          <view class="badge badge-danger">Danger</view>
          <view class="badge badge-purple">Purple</view>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">轮廓徽章</text>
        <view class="flex flex-wrap items-center" style="gap: 16rpx;">
          <view class="badge badge-outline-primary">Primary</view>
          <view class="badge badge-outline-success">Success</view>
          <view class="badge badge-outline-warning">Warning</view>
          <view class="badge badge-outline-danger">Danger</view>
          <view class="badge badge-outline-purple">Purple</view>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">标签 (Tag)</text>
        <view class="flex flex-wrap items-center" style="gap: 16rpx;">
          <view class="tag">默认标签</view>
          <view class="tag tag-primary">Primary</view>
          <view class="tag tag-success">Success</view>
          <view class="tag tag-warning">Warning</view>
          <view class="tag tag-danger">Danger</view>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">圆形标签</text>
        <view class="flex flex-wrap items-center" style="gap: 16rpx;">
          <view class="tag tag-primary tag-rounded">精选</view>
          <view class="tag tag-danger tag-rounded">热门</view>
          <view class="tag tag-success tag-rounded">推荐</view>
        </view>
      </view>
    </view>

    <!-- 头像组件 -->
    <view class="mb-8">
      <text class="text-lg font-semibold mb-4 block" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">头像组件</text>
      <view class="card">
        <text class="text-xs mb-3 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">头像尺寸</text>
        <view class="flex items-center" style="gap: 24rpx;">
          <view class="flex flex-col items-center">
            <view class="avatar avatar-xs">U</view>
            <text class="text-[10px] mt-2" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">XS</text>
          </view>
          <view class="flex flex-col items-center">
            <view class="avatar avatar-sm">U</view>
            <text class="text-[10px] mt-2" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">SM</text>
          </view>
          <view class="flex flex-col items-center">
            <view class="avatar avatar-md">U</view>
            <text class="text-[10px] mt-2" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">MD</text>
          </view>
          <view class="flex flex-col items-center">
            <view class="avatar avatar-lg">U</view>
            <text class="text-[10px] mt-2" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">LG</text>
          </view>
          <view class="flex flex-col items-center">
            <view class="avatar avatar-xl">U</view>
            <text class="text-[10px] mt-2" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">XL</text>
          </view>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">彩色头像</text>
        <view class="flex items-center" style="gap: 24rpx;">
          <view class="avatar avatar-md avatar-primary">P</view>
          <view class="avatar avatar-md avatar-success">S</view>
          <view class="avatar avatar-md avatar-warning">W</view>
          <view class="avatar avatar-md avatar-danger">D</view>
          <view class="avatar avatar-md avatar-purple">V</view>
        </view>
        <text class="text-xs mb-3 block mt-4" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">带边框头像</text>
        <view class="flex items-center" style="gap: 24rpx;">
          <view class="avatar avatar-md avatar-primary avatar-bordered">P</view>
          <view class="avatar avatar-md avatar-success avatar-bordered">S</view>
        </view>
      </view>
    </view>

    <!-- 进度条 -->
    <view class="mb-8">
      <text class="text-lg font-semibold mb-4 block" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">进度条</text>
      <view class="card">
        <view class="mb-4">
          <view class="flex justify-between mb-2">
            <text class="text-xs" style="color: {{theme === 'dark' ? '#94a3b8' : '#6b7280'}};">基础进度</text>
            <text class="text-xs" style="color: {{theme === 'dark' ? '#94a3b8' : '#6b7280'}};">75%</text>
          </view>
          <view class="progress">
            <view class="progress-bar" style="width: 75%;"></view>
          </view>
        </view>
        <view class="mb-4">
          <view class="flex justify-between mb-2">
            <text class="text-xs" style="color: {{theme === 'dark' ? '#94a3b8' : '#6b7280'}};">不同颜色</text>
          </view>
          <view class="progress progress-success mb-2">
            <view class="progress-bar" style="width: 60%;"></view>
          </view>
          <view class="progress progress-warning mb-2">
            <view class="progress-bar" style="width: 45%;"></view>
          </view>
          <view class="progress progress-danger">
            <view class="progress-bar" style="width: 30%;"></view>
          </view>
        </view>
        <view>
          <view class="flex justify-between mb-2">
            <text class="text-xs" style="color: {{theme === 'dark' ? '#94a3b8' : '#6b7280'}};">动画效果</text>
          </view>
          <view class="progress progress-lg progress-animated">
            <view class="progress-bar" style="width: 80%;"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="mb-8">
      <text class="text-lg font-semibold mb-4 block" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">分割线</text>
      <view class="card">
        <view class="divider mb-4"></view>
        <view class="divider-text mb-4"><span>带文字分割线</span></view>
        <view class="divider-dashed mb-4"></view>
        <view class="divider-dotted"></view>
      </view>
    </view>

    <!-- 节日主题 -->
    <view class="mb-8">
      <view class="flex items-center justify-between mb-4 flex-wrap" style="row-gap: 8rpx;">
        <text class="text-lg font-semibold" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">节日主题</text>
        <text class="text-xs" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">共 14 个主题</text>
      </view>
      <view class="flex flex-wrap" style="row-gap: 16rpx; column-gap: 0;">
        <view class="p-4 rounded-xl border-2 cursor-pointer transition-all" style="width: 33.3333%; border-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}}; background-color: {{theme === 'dark' ? '#1e293b' : '#ffffff'}};" data-theme="page-holiday-new-year" data-name="元旦" bindtap="switchHolidayTheme">
          <view class="w-full h-12 rounded-lg mb-3 flex items-center justify-center" style="background-color: #8b5cf6;">
            <text class="text-white text-xl">✨</text>
          </view>
          <text class="text-sm font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">元旦</text>
          <text class="text-[10px] text-center mt-05 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">1月1日</text>
        </view>
        <view class="p-4 rounded-xl border-2 cursor-pointer transition-all" style="width: 33.3333%; border-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}}; background-color: {{theme === 'dark' ? '#1e293b' : '#ffffff'}};" data-theme="page-holiday-spring" data-name="春节" bindtap="switchHolidayTheme">
          <view class="w-full h-12 rounded-lg mb-3 flex items-center justify-center" style="background-color: #dc2626;">
            <text class="text-white text-xl">🧧</text>
          </view>
          <text class="text-sm font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">春节</text>
          <text class="text-[10px] text-center mt-05 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">农历正月初一</text>
        </view>
        <view class="p-4 rounded-xl border-2 cursor-pointer transition-all" style="width: 33.3333%; border-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}}; background-color: {{theme === 'dark' ? '#1e293b' : '#ffffff'}};" data-theme="page-holiday-lantern" data-name="元宵节" bindtap="switchHolidayTheme">
          <view class="w-full h-12 rounded-lg mb-3 flex items-center justify-center" style="background-color: #ea580c;">
            <text class="text-white text-xl">🏮</text>
          </view>
          <text class="text-sm font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">元宵节</text>
          <text class="text-[10px] text-center mt-05 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">农历正月十五</text>
        </view>
        <view class="p-4 rounded-xl border-2 cursor-pointer transition-all" style="width: 33.3333%; border-color: {{theme === 'dark' ? '#818cf8' : (themeColors.primary || '#3b82f6')}}; background-color: {{theme === 'dark' ? '#1e293b' : '#ffffff'}};" data-theme="page-holiday-tomb-sweeping" data-name="清明节" bindtap="switchHolidayTheme">
          <view class="w-full h-12 rounded-lg mb-3 flex items-center justify-center" style="background-color: #16a34a;">
            <text class="text-white text-xl">🌸</text>
          </view>
          <text class="text-sm font-medium text-center" style="color: {{theme === 'dark' ? '#f1f5f9' : (themeColors.text || '#1f2937')}};">清明节</text>
          <text class="text-[10px] text-center mt-05 block" style="color: {{theme === 'dark' ? '#64748b' : '#9ca3af'}};">4月4-6日</text>
        </view>
